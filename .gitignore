# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.venv/
venv/
env/
*.so
.python-version

# =============================================================================
# Jupyter Notebooks
# =============================================================================
.ipynb_checkpoints/
*executed.ipynb

# =============================================================================
# ML Artifacts (regenerated by scripts)
# =============================================================================
# .npy files are generated by setup.sh on Streamlit Cloud (too large for git)
ml_ready/*.npy
ml_ready/*.csv
ml_ready/*.pkl                      # Ignore pkl files directly in ml_ready/
!ml_ready/preprocessor.pkl          # Except the preprocessor (3.1K — needed for dashboard)

# =============================================================================
# Report Generated Assets (regenerated by generate_report.py)
# =============================================================================
report_output/images/*.png
report_output/*.html

# =============================================================================
# Codebuff / IDE
# =============================================================================
.sixth/
streamlit.log
_*.py
_*.txt

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~
